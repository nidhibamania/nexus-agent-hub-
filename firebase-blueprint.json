{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A single chat message between a user and an agent.",
      "type": "object",
      "properties": {
        "role": {
          "type": "string",
          "enum": ["user", "model"],
          "description": "The role of the message sender."
        },
        "content": {
          "type": "string",
          "description": "The text content of the message."
        },
        "agentId": {
          "type": "string",
          "description": "The ID of the agent this message belongs to."
        },
        "uid": {
          "type": "string",
          "description": "The UID of the user who sent or received the message."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "The time the message was sent."
        }
      },
      "required": ["role", "content", "agentId", "uid", "timestamp"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about a registered user.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "The URL to the user's profile picture."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user profile was created."
        }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A productivity task or schedule item.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "title", "status", "createdAt"]
    },
    "Note": {
      "title": "Note",
      "description": "A simple text note.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "content", "createdAt"]
    }
  },
  "firestore": {
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "A collection of all chat messages across all users and agents."
    },
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "A collection of user profiles."
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "A collection of user tasks."
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "A collection of user notes."
    }
  }
}
